{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
        "label": "CMake configure: Productive (release)",
        "type": "shell",
        "command": "./cmake_config_productive_release.sh",
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "CMake configure: Unittest (debug)",
        "type": "shell",
        "command": "./cmake_config_unittest_debug.sh",
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "CMake configure: Unittest (release)",
        "type": "shell",
        "command": "./cmake_config_unittest_release.sh",
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "Clean (productive)",
        "type": "shell",
        "command": "./build_productive.sh",
        "args": [
            "clean"
        ],
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "Build (productive)",
        "type": "shell",
        "command": "./build_productive.sh",
        "args": [
            "all"
        ],
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": [
            "$gcc"
        ]
    },
    {
        "label": "Clean (unittest)",
        "type": "shell",
        "command": "./build_unittest.sh",
        "args": [
            "clean"
        ],
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "Build (unittest)",
        "type": "shell",
        "command": "./build_unittest.sh",
        "args": [
            "all"
        ],
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": [
            "$gcc"
        ]
    },
    {
        "label": "doxygen (linux_x64_tfc)",
        "type": "shell",
        "command": "./build_doxygen_linux_x64_tfc.sh",
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "Run all unittests",
        "type": "shell",
        "command": "./execute_unittests.sh",
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "Run selected unittests",
        "type": "shell",
        "command": "./execute_unittests.sh",
        "args": [
            "--gtest_filter=TestSuite.TestCase"
        ],
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    },
    {
        "label": "Run all non-death-unittests",
        "type": "shell",
        "command": "./execute_unittests.sh",
        "args": [
            "--gtest_filter=-*Death*"
        ],
        "options": {
            "cwd": "${workspaceFolder}/scripts"
        },
        "problemMatcher": []
    }
]
}
